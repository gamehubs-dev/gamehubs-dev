{
  "name": "gamehubs-dev",
  "version": "1.0.0",
  "description": "The leading open-source iGaming intelligence platform - market data, regulatory compliance, and industry analytics across 20+ global markets",
  "author": "GameHubs Research <contact@gamehubs.top>",
  "license": "MIT",
  "keywords": [
    "igaming",
    "online-gaming",
    "market-research",
    "gaming-industry",
    "regulatory-compliance",
    "kyc-aml",
    "gaming-data",
    "asia-pacific-gaming",
    "market-analytics",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gamehubs-dev/gamehubs-dev.git"
  },
  "bugs": {
    "url": "https://github.com/gamehubs-dev/gamehubs-dev/issues"
  },
  "scripts": {
    "dev": "next dev",
    "dev:debug": "node --inspect ./node_modules/.bin/next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint && prettier --check .",
    "lint:fix": "next lint --fix && prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "content:validate": "tsx scripts/validate-content.ts",
    "content:export": "tsx scripts/export-data.ts",
    "security:check": "npm audit",
    "security:scan": "snyk test",
    "prepare": "husky install"
  },
  "dependencies": {
    "@algolia/client-search": "^5.0.0",
    "@hookform/resolvers": "^3.3.4",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.10.0",
    "@tanstack/react-query": "^5.28.0",
    "@tanstack/react-table": "^8.14.0",
    "algoliasearch": "^4.22.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.0.0",
    "gray-matter": "^4.0.3",
    "ioredis": "^5.3.2",
    "lucide-react": "^0.359.0",
    "next": "14.1.0",
    "next-auth": "^4.24.6",
    "next-mdx-remote": "^4.4.1",
    "next-themes": "^0.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.0",
    "reading-time": "^1.5.0",
    "recharts": "^2.12.2",
    "rehype-highlight": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "sharp": "^0.33.2",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.22.4",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.2.0",
    "@commitlint/config-conventional": "^19.2.0",
    "@next/bundle-analyzer": "^14.1.0",
    "@playwright/test": "^1.42.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.18",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.1.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "prisma": "^5.10.0",
    "snyk": "^1.1268.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
